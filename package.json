{
  "name": "chat-bot",
  "version": "0.1.0",
  "description": "Telegram AI chat bot powered by Anthropic Claude (NestJS)",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
